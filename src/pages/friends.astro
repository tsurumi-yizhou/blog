---
import Home from "../layouts/home.astro";
import Friend from "../components/friend.astro";
import { friends } from "../data/friends.json";
---

<Home title="Friends">
    <div class="flex flex-col gap-6 px-6 pt-6">
        <div class="prose flex-grow">
            <h1>Friends</h1>
        </div>
        <div
            class="grid grid-cols-2 gap-x-6 gap-y-12 md:grid-cols-3 lg:grid-cols-4"
        >
        {
            friends.map((friend) => (
                <Friend
                    name={friend.name}
                    link={friend.link}
                    avatar={friend.avatar}
                    description={friend.description}
                />
            ))
        }
        </div>
    </div>
</Home>
