---
import App from "../App.astro";
import FriendCard from "../components/FriendCard.astro";
import {friends} from "../data/friends.json";
---
<App title="Friends">
    <main class="grid gap-x-6 gap-y-12 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {
            friends.map((friend: any) => (
                    <FriendCard
                            name={friend.name}
                            link={friend.link}
                            avatar={friend.avatar}
                            description={friend.description}
                    />
            ))
        }
    </main>
</App>