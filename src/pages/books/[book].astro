---
import Home from "../../layouts/home.astro";
import type { Book } from "../../utils/notion";
import { getBooks } from "../../utils/notion";

export const getStaticPaths = async () => {
    const books: Book[] | undefined = await getBooks();
    return books
    ?.filter(book => book.cover)
    .map((book: Book) => {
        return {
            params: { book: book.title },
        }
    }) ?? [];
};

const { book } = Astro.params;
---

<Home title={book}>
</Home>
