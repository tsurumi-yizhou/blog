---
import Home from "../layouts/home.astro";
import Book from "../components/book.astro";
import { getBooks } from "../utils/notion";

interface Book {
    title: string;
    cover: string;
    author: string;
    publisher: string;
    status: string;
    link: string;
}

var books: Book[] = [];
const data = await getBooks();
console.log(data);
---

<Home title="Books">
    <div class="flex flex-wrap">
        <div role="tablist" class="mx-auto tabs tabs-boxed">
            <a id="legere" role="tab" class="tab tab-active">读过</a>
            <a id="lectio" role="tab" class="tab">在读</a>
        </div>
        <div
            id="books"
            class="mx-auto grid grid-cols-2 gap-x-6 gap-y-12 sm:grid-cols-3 md:grid-cols-4"
        >
            {
                books.map((book) => (
                    <div
                        id={`${book.title}-${book.status}`}
                        class:list={[{ hidden: book.status == "lectio" }]}
                    >
                        <Book
                            title={book.title}
                            cover={book.cover}
                            author={book.author}
                            publisher={book.publisher}
                            link={book.link}
                        />
                    </div>
                ))
            }
        </div>
    </div>
</Home>

<script>
    const tabs = document.getElementsByClassName("tab");
    for (const tab of tabs) {
        tab.addEventListener("click", () => {
            const event = new CustomEvent("select", {
                detail: tab.id,
            });
            window.dispatchEvent(event);
        });
    }
    window.addEventListener("select", (event) => {
        for (const element of elements) {
            if (element.id == (event as CustomEvent).detail) {
                element.classList.add("tab-active");
            } else {
                element.classList.remove("tab-active");
            }
        }
    });
    const elements = document.getElementById("books")?.children!;
    window.addEventListener("select", (event) => {
        const select = (event as CustomEvent).detail;
        for (const element of elements) {
            if (element.id.endsWith(select)) {
                element.classList.remove("hidden");
            } else {
                element.classList.add("hidden");
            }
        }
    });
</script>
