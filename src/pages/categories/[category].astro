---
import Home from "../../layouts/home.astro";
import CategoryChip from "../../components/category-chip.astro";
import CoveredCard from "../../components/covered-card.astro";
import PlainCard from "../../components/plain-card.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
    return [
        ...new Set(
            (await Astro.glob("../posts/*.md"))
                .map((post) => post.frontmatter.category)
                .flat(),
        ),
    ].map((category) => {
        return {
            params: {
                category: category
            },
        };
    });
}

const { category } = Astro.params;
const posts = (await Astro.glob("../posts/*.md"));
const categories = [
    ...new Set(posts.map((post) => post.frontmatter.category).flat()),
];
---

<Home title={category}>
    <section class="block md:hidden">
        <header class="flex flex-wrap">
        {
            categories.map((it) => (
                <CategoryChip
                    category={it}
                    selected={it == category}
                />
            ))
        }
        </header>
        <main class="grid grid-cols-1 pt-12 gap-y-6">
        {
            posts
                .filter((post) => post.frontmatter.category == category)
                .map((post) => (
                    <CoveredCard
                        title={post.frontmatter.title}
                        cover={post.frontmatter.cover}
                        date={new Date(post.frontmatter.pubDate)}
                        description={post.frontmatter.description}
                        link={post.url}
                    />
                ))
        }
        </main>
    </section>
    <section class="hidden md:grid grid-cols-4">
        <aside class="col-span-1 menu rounded-box">
            <li class="menu-title">Categories</li>
            {
                categories.map((it) => (
                    <li>
                        <a
                            href={`/categories/${it}`}
                            class:list={[{ "active": it == category }]}
                        >
                            {it}
                        </a>
                    </li>
                ))
            }
        </aside>
        <nav class="col-span-3">
            <main class="grid grid-cols-2">
            {
                posts
                    .filter((post) => post.frontmatter.category == category)
                    .map((post) => (
                        <PlainCard
                            title={post.frontmatter.title}
                            category={post.frontmatter.category}
                            date={new Date(post.frontmatter.pubDate)}
                            description={post.frontmatter.description}
                            link={post.url}
                        />
                    ))
            }
            </main>
        </nav
    </section>
</Home>
